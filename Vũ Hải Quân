import 'package:flutter/material.dart';

void main() {
  runApp(const MyApp2());
}

class MyApp2 extends StatelessWidget {
  const MyApp2({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      debugShowCheckedModeBanner: false,
      title: 'Loan Calculator',
      theme: ThemeData.dark().copyWith(
        colorScheme: ColorScheme.fromSeed(
          seedColor: Colors.deepPurple,
          brightness: Brightness.dark,
        ),
      ),
      home: const LoanScreen2(),
    );
  }
}

class LoanScreen2 extends StatefulWidget {
  const LoanScreen2({super.key});

  @override
  State<LoanScreen2> createState() => _LoanScreen2State();
}

class _LoanScreen2State extends State<LoanScreen2> {
  double amount = 1000000;
  double rate = 5;
  double result = 0;

  void calculate() {
    setState(() {
      result = amount * rate / 100;
    });
  }

  @override
  void initState() {
    super.initState();
    calculate();
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text("Loan Calculator"),
        centerTitle: true,
      ),
      body: Padding(
        padding: const EdgeInsets.all(20),
        child: Column(
          children: [
            // Card kết quả (to, nổi bật)
            Container(
              width: double.infinity,
              padding: const EdgeInsets.all(24),
              decoration: BoxDecoration(
                gradient: const LinearGradient(
                  colors: [Colors.deepPurple, Colors.purpleAccent],
                ),
                borderRadius: BorderRadius.circular(20),
              ),
              child: Column(
                children: [
                  const Text(
                    "TIỀN LÃI",
                    style: TextStyle(
                      fontSize: 14,
                      letterSpacing: 1.5,
                      color: Colors.white70,
                    ),
                  ),
                  const SizedBox(height: 10),
                  Text(
                    "${result.toStringAsFixed(0)} đ",
                    style: const TextStyle(
                      fontSize: 32,
                      fontWeight: FontWeight.bold,
                    ),
                  ),
                ],
              ),
            ),

            const SizedBox(height: 30),

            // Slider số tiền
            Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text("Số tiền: ${amount.toStringAsFixed(0)} đ"),
                Slider(
                  min: 0,
                  max: 10000000,
                  value: amount,
                  onChanged: (value) {
                    setState(() {
                      amount = value;
                      calculate();
                    });
                  },
                ),
              ],
            ),

            const SizedBox(height: 20),

            // Slider lãi suất
            Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text("Lãi suất: ${rate.toStringAsFixed(1)} %"),
                Slider(
                  min: 0,
                  max: 20,
                  value: rate,
                  onChanged: (value) {
                    setState(() {
                      rate = value;
                      calculate();
                    });
                  },
                ),
              ],
            ),

            const SizedBox(height: 30),

            // Button
            SizedBox(
              width: double.infinity,
              child: ElevatedButton.icon(
                onPressed: calculate,
                icon: const Icon(Icons.calculate),
                label: const Text("Tính lại"),
                style: ElevatedButton.styleFrom(
                  padding: const EdgeInsets.symmetric(vertical: 16),
                  shape: RoundedRectangleBorder(
                    borderRadius: BorderRadius.circular(16),
                  ),
                ),
              ),
            ),
          ],
        ),
      ),
    );
  }
}
